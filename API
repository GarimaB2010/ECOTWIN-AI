import { projectId, publicAnonKey } from '../../utils/supabase/info';

const BASE_URL = `https://${projectId}.supabase.co/functions/v1/make-server-3c67677c`;

export async function callAiCoach(footprint: any, lifestyleData: any) {
  const response = await fetch(`${BASE_URL}/ai/coach`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${publicAnonKey}`
    },
    body: JSON.stringify({ footprint, lifestyleData })
  });
  return response.json();
}

